{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "headcanon-generator",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-16",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "www.headcanonforge.com",
      "custom_domain": true
    },
    {
      "pattern": "headcanonforge.com",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "headcanon-auth",
      "database_id": "6a366fd9-eb3a-4eae-97f5-129af6419e7c",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "OAUTH_REDIRECT_URI": "https://www.headcanonforge.com/api/auth/callback/google",
    "NEXT_PUBLIC_SITE_URL": "https://www.headcanonforge.com",
    "SILICONFLOW_MODEL": "deepseek-ai/DeepSeek-R1-0528-Qwen3-8B"
  }
}
